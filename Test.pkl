/// pkspec test module for this project — run with `pkf run spec`
/// (or `pkspec exec -f Test.pkl` inside the devShell).
///
/// The `schemas/` directory this amends is regenerated by `pkspec init`
/// (the `spec` task does it automatically) and is gitignored, mirroring how
/// apm's deployed skills are regenerated rather than tracked.
///
/// Add project tests as more entries in `tests`. A `Test` declares one body:
///   body = new CmdTest { cmd = "…" }            // single shell command
///   body = new SequentialTest { steps { … } }   // ordered steps
///   body = new ParallelTest { parallelSteps { … } }
amends "schemas/Test.pkl"

tests {
  new {
    name = "smoke"
    description = "Template self-check: the pkspec runner is wired up."
    body = new CmdTest { cmd = "true" }
  }
}
